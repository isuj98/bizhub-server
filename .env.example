PORT=5001
# MongoDB. Required for auth, businesses, zaps, hubs. Copy to .env and set.
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/bizhub?retryWrites=true&w=majority

# JWT secret for auth. Change in production.
JWT_SECRET=your_jwt_secret_change_in_production

# Required for AI analysis (Gemini 2.5 Flash). Copy to .env and set your key.
GEMINI_API_KEY=your_gemini_api_key_here
# Required for OpenAI model. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Base URL for the API (OAuth redirects, Zapier). Defaults: BASE_URL=http://localhost:5001, APP_ORIGIN=http://localhost:5173
BASE_URL=http://localhost:5001
APP_ORIGIN=http://localhost:5173

# Zapier OAuth 2.0 (Powered by Zapier). Required for "Connect Zapier" to work.
# Get these from https://developer.zapier.com → your app → Embed → Settings → Credentials & Redirect URIs.
ZAPIER_CLIENT_ID=your_zapier_client_id
ZAPIER_CLIENT_SECRET=your_zapier_client_secret
# Optional: OAuth scopes (default: zap zap:write authentication)
# ZAPIER_OAUTH_SCOPE=zap zap:write authentication

# OAuth v2 when BizHub acts as the OAuth provider for Zapier.
# If omitted, ZAPIER_CLIENT_ID / ZAPIER_CLIENT_SECRET are reused.
# ZAPIER_OAUTH_CLIENT_ID=your_oauth_client_id
# ZAPIER_OAUTH_CLIENT_SECRET=your_oauth_client_secret
# Comma-separated exact allowlist of Zapier redirect URIs.
ZAPIER_OAUTH_REDIRECT_URIS=https://zapier.com/dashboard/auth/oauth/return/App237819CLIAPI/
# Optional defaults:
# ZAPIER_OAUTH_DEFAULT_EMAIL=owner@bizhub.app
# ZAPIER_OAUTH_ACCESS_TTL_SECONDS=3600
# ZAPIER_OAUTH_REFRESH_TTL_SECONDS=2592000
# ZAPIER_OAUTH_CODE_TTL_SECONDS=300
# If DB is unavailable, authorize can use these fallback credentials:
# ZAPIER_OAUTH_FALLBACK_EMAIL=owner@bizhub.app
# ZAPIER_OAUTH_FALLBACK_PASSWORD=change_me
